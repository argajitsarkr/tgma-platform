# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Database
DATABASE_URL=postgresql://tgma_user:change-me-strong-password@localhost:5432/tgma_db

# Upload settings
UPLOAD_FOLDER=/data/tgma/uploads
MAX_CONTENT_LENGTH=52428800

# KoboToolbox (for ETL sync)
KOBO_API_URL=https://kf.kobotoolbox.org
KOBO_API_TOKEN=your-kobo-api-token
KOBO_FORM_ID=your-form-asset-uid

# Budget (in Lakhs INR)
BUDGET_SEQUENCING=30
BUDGET_HORMONES=11
BUDGET_SHIPMENT=1
