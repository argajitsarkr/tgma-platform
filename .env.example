# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Database
DATABASE_URL=postgresql://tgma_user:change-me-strong-password@localhost:5432/tgma_db
DB_PASSWORD=change-me-strong-password

# Docker — host port for the web container (pick one not in use)
WEB_PORT=8100

# Upload settings
UPLOAD_FOLDER=/data/tgma/uploads
MAX_CONTENT_LENGTH=52428800

# KoboToolbox (for ETL sync)
KOBO_API_URL=https://kf.kobotoolbox.org
KOBO_API_TOKEN=your-kobo-api-token
KOBO_FORM_ID=your-form-asset-uid

# Budget (in Lakhs INR)
BUDGET_SEQUENCING=30
BUDGET_HORMONES=11
BUDGET_SHIPMENT=1

# Ngrok tunnel — get your free authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# After adding this, the platform will be accessible from outside the LAN via a public HTTPS URL.
# Run: sudo docker compose logs ngrok | grep url=   to find the current public URL.
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
